AGENT_NAME="Will"
INITIAL_BUDGET=0.0
LOG_FILE="logs/agent_will.log"
STATE_FILE="state.json"

# Required -- Will's autonomous decision making and content generation
ANTHROPIC_API_KEY=""

# Required -- get one at serper.dev
WEB_SEARCH_API_KEY=""

# Optional -- unlocks full Twitter/X data via RapidAPI, falls back to Serper if not set
RAPIDAPI_KEY=""

OPENCLAW_MODEL="claude-sonnet-4-6"
HEARTBEAT_INTERVAL=1800
MAX_CONSECUTIVE_FAILURES=3

# Optional -- heartbeat alerts
DISCORD_WEBHOOK_URL=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

AGENT_WILL_STATUS_ENDPOINT="http://localhost:8000/status"